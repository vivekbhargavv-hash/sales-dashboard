# ── Security ──────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-64-char-hex-string

# JWT token lifespan in hours
ACCESS_TOKEN_EXPIRE_HOURS=24

# ── Database ──────────────────────────────────────────────────────
# Local dev (SQLite — file stored next to main.py)
DATABASE_URL=sqlite:///./moeving.db

# Production (PostgreSQL on Render — paste the Internal Database URL)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── CORS ──────────────────────────────────────────────────────────
# Your deployed Vercel frontend URL (no trailing slash)
FRONTEND_URL=https://your-app.vercel.app

# ── Upload limits ─────────────────────────────────────────────────
MAX_FILE_MB=20
